# ============================================================
# Binance Spot Testnet credentials
# ============================================================
# Use Binance Spot Testnet keys only.
# Never add production Binance API keys to this project.
# Never commit a real .env file to Git.

BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_SPOT_TESTNET_BASE_URL=https://testnet.binance.vision

# ============================================================
# Trading configuration
# ============================================================
TRADING_SYMBOL=DOGEUSDT
TRADING_INTERVAL=5m

# ============================================================
# Paper broker configuration
# ============================================================
PAPER_INITIAL_QUOTE_BALANCE=1000
PAPER_FEE_BPS=10
PAPER_SLIPPAGE_BPS=5
PAPER_MAX_POSITION_QUOTE_PCT=0.25
PAPER_MIN_QUOTE_ORDER_QTY=5

# ============================================================
# Safety switch
# ============================================================
# Keep false by default.
# Set true only if you deliberately want to enable Spot Testnet order validation.
# This project is intended to run in paper trading mode, without real capital.
ALLOW_LIVE_TESTNET_ORDERS=false
